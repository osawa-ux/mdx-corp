# MDX株式会社 Search Console API 設定
# このファイルを .env にコピーして使用してください
#   cp .env.example .env

# --- Search Console ---
# プロパティURL (末尾スラッシュ含む)
# ドメインプロパティの場合: sc-domain:mdx-inc.co.jp
# URLプレフィックスの場合: https://mdx-inc.co.jp/
SEARCH_CONSOLE_SITE_URL=sc-domain:mdx-inc.co.jp

# サイトマップURL
SEARCH_CONSOLE_SITEMAP_URL=https://mdx-inc.co.jp/sitemap.xml

# URL Inspection のデフォルト対象 (カンマ区切り)
INSPECT_DEFAULT_URLS=https://mdx-inc.co.jp/,https://mdx-inc.co.jp/careers.html,https://mdx-inc.co.jp/privacy.html,https://mdx-inc.co.jp/disclaimer.html

# --- 認証 (OAuth 2.0) ---
# Google Cloud Console からダウンロードした OAuth クライアントID ファイル
# OAUTH_CREDENTIALS_FILE=credentials.json

# OAuth トークン保存先 (初回認証後に自動生成)
# TOKEN_FILE=token.json

# --- 認証 (サービスアカウント / GitHub Actions 向け) ---
# サービスアカウントのキーファイルパス
# この変数が設定されていれば OAuth より優先される
# GOOGLE_APPLICATION_CREDENTIALS=service-account-key.json
